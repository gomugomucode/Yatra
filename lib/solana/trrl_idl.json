  "types": [
    {
      "name": "DriverRep",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "driver",
            "docs": [
              "The driver's Solana public key — this is the portable identity"
            ],
            "type": "pubkey"
          },
          {
            "name": "score",
            "docs": [
              "Composite score 0–1000"
            ],
            "type": "u16"
          },
          {
            "name": "total_trips",
            "docs": [
              "All trips ever accepted"
            ],
            "type": "u32"
          },
          {
            "name": "completed_trips",
            "docs": [
              "Trips that reached completion"
            ],
            "type": "u32"
          },
          {
            "name": "avg_rating_x100",
            "docs": [
              "avgRating * 100 — stored as integer to avoid floats (485 = 4.85★)"
            ],
            "type": "u16"
          },
          {
            "name": "on_time_arrivals",
            "docs": [
              "Trips where driver arrived within the ETA window"
            ],
            "type": "u32"
          },
          {
            "name": "zk_verified",
            "docs": [
              "ZK civic identity verified via Groth16 proof"
            ],
            "type": "bool"
          },
          {
            "name": "sos_triggered",
            "docs": [
              "SOS events triggered — each costs 20 score points"
            ],
            "type": "u16"
          },
          {
            "name": "last_updated",
            "docs": [
              "Unix timestamp of last update"
            ],
            "type": "i64"
          },
          {
            "name": "last_platform",
            "docs": [
              "Platform that last wrote to this record"
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "docs": [
              "Bump seed for the PDA"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "PlatformEntry",
      "docs": [
        "One PDA per registered platform.",
        "Seeds: [\"platform\", platform_pubkey]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "platform",
            "docs": [
              "The platform's signing keypair pubkey"
            ],
            "type": "pubkey"
          },
          {
            "name": "name",
            "docs": [
              "Human-readable name, e.g. \"Yatra\", \"Pathao\""
            ],
            "type": "string"
          },
          {
            "name": "is_active",
            "docs": [
              "False = deregistered, cannot submit rep updates"
            ],
            "type": "bool"
          },
          {
            "name": "registered_at",
            "docs": [
              "When this platform was registered"
            ],
            "type": "i64"
          },
          {
            "name": "total_updates",
            "docs": [
              "Total rep updates submitted by this platform"
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
